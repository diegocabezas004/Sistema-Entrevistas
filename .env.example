# === Configuración del Simulador de Entrevistas Técnicas ===
# Copia este archivo a .env y coloca tus valores reales.
# NUNCA subas el archivo .env al repositorio (RNF-02).

# --- Anthropic API ---
# Obtén tu clave en https://console.anthropic.com/
ANTHROPIC_API_KEY=coloca_tu_api_key_aqui

# Modelo por defecto (configurable sin tocar código).
# claude-haiku-4-5 es el más económico y suficiente para este alcance.
ANTHROPIC_MODEL=claude-haiku-4-5

# Límite de tokens de salida por llamada a la IA.
ANTHROPIC_MAX_TOKENS=1500

# Reintentos ante fallo de validación de JSON (RF-12 / RNF-06).
AI_MAX_RETRIES=1

# --- Base de datos (SQLite local para la defensa) ---
DATABASE_URL=sqlite:///./entrevistas.db

# --- Servidor ---
APP_HOST=127.0.0.1
APP_PORT=8000
